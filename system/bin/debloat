#!/system/bin/sh

echo "[+] Memulai debloat dan matikan service berat..."
logfile="/data/local/tmp/debloated_packages.txt"
rm -f "$logfile"
touch "$logfile"

# Fungsi uninstall + log
uninstall_pkg() {
  pkg="$1"
  if pm list packages | grep -q "$pkg"; then
    echo "[-] Uninstall $pkg"
    pm uninstall --user 0 "$pkg" && echo "$pkg" >> "$logfile"
  fi
}

# Fungsi heavy disable service 
disable_service() {
  echo "[-] Disable service: $1"
  stop "$1" 2>/dev/null
}

# 🔧 Matikan service berat Samsung
disable_service com.samsung.android.bixby.service
disable_service com.samsung.android.kidsinstaller
disable_service com.samsung.android.tvplus
disable_service com.samsung.android.game.gos
disable_service com.samsung.android.spay
disable_service com.samsung.android.mdx
disable_service com.samsung.android.rubin.app
disable_service com.samsung.android.scloud
disable_service com.samsung.systemui.bixby2
disable_service com.samsung.android.app.tips
# 🔧 Google apps aman dihapus
